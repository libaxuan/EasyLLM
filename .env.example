# EasyLLM Configuration
# Copy this file to .env and modify as needed

# Server
SERVER_PORT=8021
SERVER_HOST=0.0.0.0

# Debug mode (set to true for verbose logging)
DEBUG=false

# Data directory
DATA_DIR=./data

# Secret key (change this in production!)
SECRET_KEY=easyllm-secret-key-change-in-production

# Database (sqlite or postgres)
DB_TYPE=sqlite
DB_SQLITE_PATH=./data/easyllm.db

# PostgreSQL (only needed if DB_TYPE=postgres)
# DB_DSN=host=localhost user=postgres password=yourpassword dbname=easyllm port=5432 sslmode=disable

# HTTP Proxy (optional)
PROXY_ENABLED=false
PROXY_HOST=
PROXY_PORT=7890
PROXY_USERNAME=
PROXY_PASSWORD=
